# ============================================================
# MINIMARKET SYSTEM — Variables de Entorno
# Copiar a .env y completar los valores
# NUNCA subir .env al repositorio
# ============================================================

# ─── Base de Datos ───────────────────────────────────────────
DB_PASSWORD=MinimarketDB_Secure#2025!

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=RedisSecure#2025!

# ─── MinIO (Almacenamiento de Imágenes) ──────────────────────
MINIO_USER=minimarket_admin
MINIO_PASSWORD=MinioSecure#2025!

# ─── JWT Secrets (mínimo 256 bits / 32 caracteres) ───────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secret_aleatorio_de_minimo_64_caracteres_hexadecimales_aqui
JWT_REFRESH_SECRET=cambiar_por_otro_secret_aleatorio_diferente_al_anterior_aqui

# ─── SMTP (Email para recuperación de contraseña) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail

# ─── Frontend URL (para CORS) ────────────────────────────────
FRONTEND_URL=http://localhost

# ─── Microservicio IA ────────────────────────────────────────
IA_SERVICE_URL=http://localhost:8001

# ─── Configuración del Negocio (usada en seed inicial) ───────
NEGOCIO_NOMBRE=Mi Minimarket
NEGOCIO_DIRECCION=Av. Siempre Viva 742
NEGOCIO_TELEFONO=2-123456
NEGOCIO_NIT=1234567
